# ════════════════════════════════════════════════════════════════════
#  GrantSetu — Production Environment Variables
#  Copy this file to .env on your server, fill in all values,
#  then run: docker compose --env-file .env up -d
# ════════════════════════════════════════════════════════════════════

# ── Frontend (Next.js) ───────────────────────────────────────────────
# Your live domain (no trailing slash)
NEXTAUTH_URL=https://grantsetu.in

# Run this to generate: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# Google OAuth — from console.cloud.google.com
# Authorized redirect URI to add: https://grantsetu.in/api/auth/callback/google
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET

# Public API URL (used by the browser to call the backend)
NEXT_PUBLIC_API_URL=https://api.grantsetu.in

# ── Database ─────────────────────────────────────────────────────────
# Strong random password — used by both PostgreSQL and the backend .env
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
